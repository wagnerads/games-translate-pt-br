	/// ingredients
	{"code":"ingredientsettings","text":"Opções dos Ingredientes"},
	{"code":"locationsIncluded","text":"Locais inclusos"},
	{"code":"hovertext.locationsIncluded","text":"Quais locais serão adicionados no jogo. Os Ingredientes adicionados serão divididos entre os jogadores para criar um jogo melhor ."},
	{"code":"numberOfIngredients","text":"Número de Ingredientes"},
	{"code":"hovertext.numberOfIngredients","text":"O Número total de ingredientes no jogo, incluido os iniciais."},
	{"code":"numberOfStartingIngredients","text":"Número de ingredientes iniciais"},
	{"code":"hovertext.numberOfStartingIngredients","text":"O Número de ingredientes que os jogadores irão começar."},
	{"code":"maxCatalystLevel","text":"Nível Máximo de Catalisadores"},
	{"code":"hovertext.maxCatalystLevel","text":"O Nível Máximo de Catalisadores no jogo."},
	{"code":"numberOfCatalysts","text":"Número de Catalisadores"},
	{"code":"hovertext.numberOfCatalysts","text":"O Número de catalisadores no jogo. Catalisadores vão ser distribuidos baseados no nível máximo de catalisadores. Haverá mais catalisadores de baixo nível do que catalisadores de alto nível."},
	{"code":"numberOfSideEffects","text":"Número de efeitos colateráis"},
	{"code":"hovertext.numberOfSideEffects","text":"O número de efeitos secundários não catalisadores para incluir(alem dos catalisadores)."},
	/// game settings
	{"code":"gamesettings","text":"Opções de Jogo"},
	{"code":"mapSize","text":"Tamanho do Mapa"},
	{"code":"hovertext.mapSize","text":"O tamanho do mapa. Grandes mapas são mais propensos a incluir grandes edifícios."},
	{"code":"eventFrequency","text":"Freqüência do evento"},
	{"code":"hovertext.eventFrequency","text":"A freqüência de eventos aleatórios que afetam a demanda de cura."},
	{"code":"cureMarketSize","text":"Tamanho do mercado de cura"},
	{"code":"hovertext.cureMarketSize","text":"O tamanho do mercado de cura. Esta percentagem é aplicada diretamente à estatística 'Número de doentes' de cada cura. Um mercado menor vai saturar mais rápido e diminuirá mais rápido em resposta a curas permanentes."},
	{"code":"loanInterestFactor","text":"Taxas de juros do empréstimo"},
	{"code":"hovertext.loanInterestFactor","text":"Esta configuração afeta as taxas de juros oferecidas em empréstimos. Taxas de juros mais altas facilitam a espiral de dívida e incentivam os jogadores a pagar empréstimos antecipadamente."},
	{"code":"cureMarginBonus","text":"Margem de lucro das curas"},
	{"code":"hovertext.cureMarginBonus","text":"Esta configuração é a forma mais direta de mudar a dificuldade e duração do jogo. Margens altas de cura facilitam ganhar dinheiro mais rapidamente. Margens baixas tornam mais difícil obter lucro e resultarão em um jogo mais lento. Margens baixas forçam o jogador a procurar 'bons negócios' e focar em curas que estão em alta demanda."},
	{"code":"exploreSpeed","text":"Velocidade de exploração"},
	{"code":"hovertext.exploreSpeed","text":"Esta configuração determina quanto tempo leva para explorar um local. Isso afeta o custo da exploração porque os salários são cobrados diariamente. Para criar um jogo mais rápido sem diminuir a dificuldade, tente aumentar a velocidade de exploração e os salários dos exploradores."},
	{"code":"researchSpeed","text":"Velocidade de pesquisa"},
	{"code":"hovertext.researchSpeed","text":"Esta configuração determina quanto tempo leva para pesquisar um projeto. Isso afeta o custo da pesquisa porque os salários são cobrados diariamente. Para criar um jogo mais rápido sem diminuir a dificuldade, tente aumentar a velocidade de pesquisa e os salários dos cientistas."},
	{"code":"testingSpeed","text":"Velocidade do analisador"},
	{"code":"hovertext.testingSpeed","text":"Esta configuração determina quantos médicamentos devem ser analisados antes que a concentração de força máxima seja revelada."},
	{"code":"startingMoney","text":"Dinheiro inicial"},
	{"code":"hovertext.startingMoney","text":"A quantidade de dinheiro com que cada jogador começa."},
	{"code":"startingLoan","text":"Empréstimo inicial"},
	{"code":"hovertext.startingLoan","text":"A quantidade de empréstimo com que o jogador começa. Concorrentes de IA não são afetados."},
	{"code":"patentSpeed","text":"Velocidade da patente"},
	{"code":"hovertext.patentSpeed","text":"Esta configuração determina quanto tempo leva para concluir uma patente."},
	{"code":"patentCost","text":"Custo da patente"},
	{"code":"hovertext.patentCost","text":"Esta configuração determina quanto custa para solicitar uma patente."},
	{"code":"plotCost","text":"Custo do terreno"},
	{"code":"hovertext.plotCost","text":"Esta configuração determina quanto custa para expandir sua fábrica."},
	{"code":"researchSalaries","text":"Salários dos cientistas"},
	{"code":"hovertext.researchSalaries","text":"O valor que custa por dia para empregar um Cientista."},
	{"code":"researchHireCost","text":"Custo de contratação de cientistas"},
	{"code":"hovertext.researchHireCost","text":"O custo único de contratar um Cientista."},
	{"code":"explorerSalaries","text":"Salários dos exploradores"},
	{"code":"hovertext.explorerSalaries","text":"O valor que custa por dia para empregar um Explorador."},
	{"code":"explorerHireCost","text":"Custo de contratação de exploradores"},
	{"code":"hovertext.explorerHireCost","text":"O custo único de contratar um Explorador."},
	{"code":"ingredientPrices","text":"Preços dos ingredientes"},
	{"code":"hovertext.ingredientPrices","text":"Determina o custo dos ingredientes importados para sua fábrica. Preços baixos de ingredientes tornam o jogo geralmente mais fácil, mas em particular, tornam o uso de catalisadores menos proibitivo em termos de custo. O oposto também é verdadeiro."},
	{"code":"processCosts","text":"Custos de processamento"},
	{"code":"hovertext.processCosts","text":"Determina o custo básico de processamento de todas as máquinas, reduções no custo de processamento de atualizações são mantidas inalterádas. Uma configuração mais baixa resulta em um jogo geralmente mais fácil enquanto torna as atualizações mais eficazes. O oposto também é verdadeiro."},
	{"code":"buildCosts","text":"Custos de construção"},
	{"code":"hovertext.buildCosts","text":"Determina o custo de construção de todas as máquinas. Uma configuração mais alta resultará em um jogo mais longo e mais intensivo em capital. Uma configuração baixa resultará em um jogo mais rápido onde o espaço da fábrica é o principal fator limitante."},
	{"code":"researchAccrualSpeed","text":"Velocidade de acúmulo de pontos de melhoria de pesquisa"},
	{"code":"hovertext.researchAccrualSpeed","text":"Determina a taxa na qual os pontos de melhoria de pesquisa se acumulam. Uma configuração mais baixa tornará mais econômico pesquisar novas tecnologias do que melhorar as existentes. O oposto também é verdadeiro."},
	{"code":"explorationAccrualSpeed","text":"Velocidade de acúmulo de pontos de melhoria de ingredientes"},
	{"code":"hovertext.explorationAccrualSpeed","text":"Determina a taxa na qual os pontos de melhoria de ingredientes se acumulam. Uma configuração mais baixa tornará mais econômico explorar novos locais do que melhorar os existentes. O oposto também é verdadeiro."},
	{"code":"cureRate","text":"Taxa de cura"},
	{"code":"hovertext.cureRate","text":"A taxa na qual os tratamentos curam permanentemente os pacientes."},
	{"code":"infectionRate","text":"Taxa de infecção"},
	{"code":"hovertext.infectionRate","text":"A taxa na qual a demanda por curas que tratam doenças infecciosas aumenta ao longo do tempo. Uma configuração mais alta realmente torna o jogo mais fácil porque torna essas curas mais lucrativas mais cedo."},
